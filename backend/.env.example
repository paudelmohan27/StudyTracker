# Backend Environment Variables
# Copy this file to .env and fill in your values
# ⚠️ CRITICAL: NEVER commit your actual .env file to GitHub

# ──────── Server ────────
# Port the Express server runs on
PORT=5000
# Node environment (development, production)
NODE_ENV=development

# ──────── Database ────────
# ⚠️ CRITICAL: MongoDB connection string containing database credentials
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/studytracker?retryWrites=true&w=majority

# ──────── Security ────────
# ⚠️ CRITICAL: Secret key used to sign JWT tokens
# Must be at least 32 random characters in production
JWT_SECRET=your_minimum_32_character_secret_key_here
# How long the JWT remains valid
JWT_EXPIRES_IN=7d

# ──────── CORS / Frontend Link ────────
# Which frontend URL is allowed to access the API (Useful for production: https://your-frontend.vercel.app)
CLIENT_URL=http://localhost:5173

# ──────── Cloudinary (Media Uploads) ────────
# Your Cloudinary account name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
# ⚠️ CRITICAL: Your Cloudinary API Key
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
# ⚠️ CRITICAL: Your Cloudinary API Secret
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ──────── Email (Resend API) ────────
# Resend is used instead of SMTP because Render's free tier blocks outbound SMTP ports.
# Sign up free at https://resend.com → API Keys → Create key
# ⚠️ CRITICAL: Your Resend API Key
RESEND_API_KEY=re_your_api_key_here
# Sender name shown in email clients
FROM_NAME=StudyTracker
# Sender address - must be a verified domain in Resend, OR use onboarding@resend.dev for testing
FROM_EMAIL=onboarding@resend.dev
