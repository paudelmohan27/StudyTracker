# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB - Replace with your Atlas connection string
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/studytracker?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/studytracker?retryWrites=true&w=majority

# JWT Secret - Use a long random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars

# JWT Token Expiry
JWT_EXPIRES_IN=7d

# Client URL for CORS
CLIENT_URL=http://localhost:5173
